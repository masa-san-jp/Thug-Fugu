{
  "models": [
    {"name": "echo-general", "backend": "echo", "model": "general-local-mock"}
  ],
  "roles": [
    {"name": "worker", "model": "echo-general", "always_include": true},
    {"name": "synthesizer", "model": "echo-general", "is_synthesizer": true}
  ],
  "tool_calling": {
    "enabled": true,
    "mode": "synthesizer_only",
    "execute": true,
    "allowed_tools": ["echo", "lookup_static"],
    "timeout_seconds": 5,
    "max_output_chars": 4000
  },
  "orchestrator": {"selection_policy": "all", "temperature": 0.2}
}
