{
  "models": [
    {
      "name": "local-thinker",
      "backend": "ollama",
      "model": "gpt-oss:20b",
      "base_url": "http://127.0.0.1:11434",
      "timeout_seconds": 300
    },
    {
      "name": "local-reviewer",
      "backend": "ollama",
      "model": "gpt-oss:20b",
      "base_url": "http://127.0.0.1:11434",
      "timeout_seconds": 300
    },
    {
      "name": "local-synth",
      "backend": "ollama",
      "model": "gpt-oss:20b",
      "base_url": "http://127.0.0.1:11434",
      "timeout_seconds": 300
    }
  ],
  "roles": [
    {
      "name": "thinker",
      "model": "local-thinker",
      "system_prompt": "あなたは計画担当。タスクを分解し、方針とリスクを簡潔に示す。",
      "always_include": true
    },
    {
      "name": "reviewer",
      "model": "local-reviewer",
      "system_prompt": "あなたは検証担当。別視点で正しさ・抜け・運用リスクを簡潔に点検する。",
      "always_include": true
    },
    {
      "name": "synthesizer",
      "model": "local-synth",
      "system_prompt": "あなたは統合担当。worker 出力を1つの簡潔な回答にまとめる。",
      "is_synthesizer": true
    }
  ],
  "orchestrator": {
    "selection_policy": "all",
    "max_parallel_workers": 3,
    "temperature": 0.2,
    "request_timeout_seconds": 180
  }
}
